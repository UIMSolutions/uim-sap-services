dependency "json" version="~2.0.0"
dependency "vibe-d:tls" version="~0.9.0"
dependency "vibe-d:auth" version="~0.9.0"
dependency "vibe-d:logging" version="~0.9.0"
dependency "vibe-d:database" version="~0.9.0"