@startuml class_model
!theme plain

title UIM SAP Identity Provisioning (IPV) - Class Model

package "uim.sap.identityprovisioning" {
  class IPVConfig {
    +host : string
    +port : ushort
    +basePath : string
    +serviceName : string
    +serviceVersion : string
    +requireAuthToken : bool
    +authToken : string
    +validate()
  }

  class IPVServer {
    -_service : IPVService
    +run()
    -handleRequest()
    -validateAuth()
    -normalizedSegments()
    -respondError()
  }

  class IPVService {
    -_config : IPVConfig
    -_store : IPVStore
    +health() : Json
    +ready() : Json
    +createSystem() : Json
    +listSystems() : Json
    +getSystem() : Json
    +updateSystem() : Json
    +deleteSystem() : Json
    +createUser() : Json
    +listUsers() : Json
    +getUser() : Json
    +updateUser() : Json
    +deleteUser() : Json
    +createGroup() : Json
    +listGroups() : Json
    +getGroup() : Json
    +deleteGroup() : Json
    +createTransformation() : Json
    +listTransformations() : Json
    +deleteTransformation() : Json
    +runJob() : Json
    +listJobs() : Json
    +getJob() : Json
    +cancelJob() : Json
    +listJobLogs() : Json
    +exportJobLogs() : Json
    +createNotification() : Json
    +listNotifications() : Json
    +deleteNotification() : Json
    +dashboard() : Json
    -executeProvisioning()
    -applyUserTransformations()
    -notifySubscribers()
  }

  class IPVStore {
    -_systems : IPVSystem[string]
    -_users : IPVUser[string]
    -_groups : IPVGroup[string]
    -_transformations : IPVTransformation[string]
    -_jobs : IPVJob[string]
    -_jobLogs : IPVJobLog[string][]
    -_notifications : IPVNotification[string]
    -_lock : Mutex
    +upsertSystem() : IPVSystem
    +getSystem() : IPVSystem
    +listSystems() : IPVSystem[]
    +deleteSystem() : bool
    +upsertUser() : IPVUser
    +getUser() : IPVUser
    +listUsers() : IPVUser[]
    +deleteUser() : bool
    +upsertGroup() : IPVGroup
    +getGroup() : IPVGroup
    +listGroups() : IPVGroup[]
    +deleteGroup() : bool
    +upsertTransformation() : IPVTransformation
    +listTransformations() : IPVTransformation[]
    +deleteTransformation() : bool
    +upsertJob() : IPVJob
    +getJob() : IPVJob
    +listJobs() : IPVJob[]
    +deleteJob() : bool
    +appendJobLog()
    +listJobLogs() : IPVJobLog[]
    +upsertNotification() : IPVNotification
    +listNotifications() : IPVNotification[]
    +deleteNotification() : bool
  }

  struct IPVSystem {
    +tenantId : string
    +systemId : string
    +systemName : string
    +systemType : string
    +connectorType : string
    +endpointUrl : string
    +authType : string
    +status : string
    +userCount : long
    +groupCount : long
    +toJson() : Json
  }

  struct IPVUser {
    +tenantId : string
    +userId : string
    +userName : string
    +email : string
    +firstName : string
    +lastName : string
    +active : bool
    +status : string
    +groupIds : string[]
    +toJson() : Json
  }

  struct IPVGroup {
    +tenantId : string
    +groupId : string
    +groupName : string
    +description : string
    +memberUserIds : string[]
    +toJson() : Json
  }

  struct IPVTransformation {
    +tenantId : string
    +transformationId : string
    +systemId : string
    +entityType : string
    +action : string
    +sourceAttribute : string
    +targetAttribute : string
    +condition : string
    +priority : int
    +active : bool
    +toJson() : Json
  }

  struct IPVJob {
    +tenantId : string
    +jobId : string
    +jobName : string
    +sourceSystemId : string
    +targetSystemIds : string[]
    +readMode : string
    +status : string
    +usersRead : long
    +usersWritten : long
    +usersSkipped : long
    +usersFailed : long
    +groupsRead : long
    +groupsWritten : long
    +groupsSkipped : long
    +groupsFailed : long
    +deltaToken : string
    +toJson() : Json
  }

  struct IPVJobLog {
    +tenantId : string
    +logId : string
    +jobId : string
    +level : string
    +entityType : string
    +entityId : string
    +message : string
    +timestamp : string
    +toJson() : Json
  }

  struct IPVNotification {
    +tenantId : string
    +subscriptionId : string
    +sourceSystemId : string
    +callbackUrl : string
    +eventTypes : string[]
    +active : bool
    +toJson() : Json
  }
}

' Relationships
IPVServer --> IPVService : delegates
IPVService --> IPVStore : persists
IPVService --> IPVConfig : reads

IPVStore *-- IPVSystem
IPVStore *-- IPVUser
IPVStore *-- IPVGroup
IPVStore *-- IPVTransformation
IPVStore *-- IPVJob
IPVStore *-- IPVJobLog
IPVStore *-- IPVNotification

IPVJob --> IPVSystem : sourceSystemId
IPVTransformation --> IPVSystem : systemId
IPVUser --> IPVSystem : sourceSystemId
IPVUser --> IPVGroup : groupIds

@enduml
