@startuml sequence_consolidation_quality
!theme plain

title MDG Sequence - Consolidation and Data Quality Evaluation

actor Client
participant "MDGServer" as Server
participant "MDGService" as Service
participant "MDGStore" as Store

== Duplicate Detection ==
Client -> Server : GET /v1/tenants/{tenant}/consolidation/duplicates
Server -> Service : detectDuplicates(tenantId)
Service -> Store : listBusinessPartners(tenantId)
Store --> Service : MDGBusinessPartner[]
Service -> Service : detectDuplicateCandidates(...)
Service --> Server : duplicate candidates
Server --> Client : 200 OK

== Merge Best Record ==
Client -> Server : POST /v1/tenants/{tenant}/consolidation/merge
Server -> Service : mergeDuplicates(tenantId, request)
Service -> Store : getBusinessPartner(primary)
Store --> Service : primary BP
Service -> Store : getBusinessPartner(duplicate)
Store --> Service : duplicate BP
Service -> Service : merge missing fields into primary
Service -> Store : upsertBusinessPartner(primary)
Service -> Store : deleteBusinessPartner(duplicate)
Service --> Server : best_record payload
Server --> Client : 200 OK

== Quality Evaluation ==
Client -> Server : POST /v1/tenants/{tenant}/quality/evaluate
Server -> Service : evaluateDataQuality(tenantId)
Service -> Store : listRules(tenantId)
Store --> Service : MDGQualityRule[]
Service -> Store : listBusinessPartners(tenantId)
Store --> Service : MDGBusinessPartner[]
Service -> Service : passesRule(bp, rule)
Service --> Server : score + violations
Server --> Client : 200 OK

@enduml
